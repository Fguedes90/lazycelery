        // Full backward cycle should return to start
        handle_key_event(create_key_event(KeyCode::BackTab), &mut app);
        handle_key_event(create_key_event(KeyCode::BackTab), &mut app);
        handle_key_event(create_key_event(KeyCode::BackTab), &mut app);
