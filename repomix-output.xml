    let help_text = vec![
        Line::from("LazyCelery - Keyboard Shortcuts"),
        Line::from(""),
        Line::from("Navigation:"),
        Line::from("  Tab       - Switch between tabs"),
        Line::from("  ↑/k       - Move up"),
